{
  "name": "puthtotalk",
  "displayName": "PuthToTalk - Voice Input",
  "description": "Local voice input via Whisper. Dictate prompts and text, copy from Voice Log.",
  "version": "0.3.4",
  "publisher": "artisanweblab",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OleksandrWebLab/pathtotalk-vs-code-plugin.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "puthtotalk.startRecording",
        "title": "Voice: Start Recording"
      },
      {
        "command": "puthtotalk.stopRecording",
        "title": "Voice: Stop Recording"
      },
      {
        "command": "puthtotalk.toggleRecording",
        "title": "Voice: Start / Stop Recording"
      },
      {
        "command": "puthtotalk.cancelRecording",
        "title": "Voice: Cancel Recording (discard)"
      },
      {
        "command": "puthtotalk.showLog",
        "title": "Voice: Show Log"
      },
      {
        "command": "puthtotalk.copyLastTranscription",
        "title": "Voice: Copy Last Transcription"
      },
      {
        "command": "puthtotalk.searchLog",
        "title": "Voice: Search Log"
      },
      {
        "command": "puthtotalk.clearProjectLog",
        "title": "Voice: Clear Project Log"
      },
      {
        "command": "puthtotalk.exportLogMarkdown",
        "title": "Voice: Export Log as Markdown"
      },
      {
        "command": "puthtotalk.openLogFile",
        "title": "Voice: Open Log File"
      },
      {
        "command": "puthtotalk.openStorageFolder",
        "title": "Voice: Open Project Storage Folder"
      },
      {
        "command": "puthtotalk.openGlobalStorageFolder",
        "title": "Voice: Open Global Storage Folder"
      },
      {
        "command": "puthtotalk.changeModel",
        "title": "Voice: Change Model"
      },
      {
        "command": "puthtotalk.changeLanguage",
        "title": "Voice: Change Language"
      },
      {
        "command": "puthtotalk.changeDevice",
        "title": "Voice: Change Compute Device"
      },
      {
        "command": "puthtotalk.restartServer",
        "title": "Voice: Restart Server"
      },
      {
        "command": "puthtotalk.showServerLogs",
        "title": "Voice: Show Server Logs"
      },
      {
        "command": "puthtotalk.showExtensionLogs",
        "title": "Voice: Show Extension Logs"
      },
      {
        "command": "puthtotalk.downloadModel",
        "title": "Voice: Download Model"
      },
      {
        "command": "puthtotalk.resetExtension",
        "title": "Voice: Reset Extension"
      },
      {
        "command": "puthtotalk.transcribeFile",
        "title": "Voice: Transcribe File..."
      },
      {
        "command": "puthtotalk.showTranscripts",
        "title": "Voice: Show Transcripts"
      },
      {
        "command": "puthtotalk.toggleStreamingMode",
        "title": "Voice: Change Streaming Mode (off / adaptive / on)"
      },
      {
        "command": "puthtotalk.editVocabulary",
        "title": "Voice: Edit Project Vocabulary"
      },
      {
        "command": "puthtotalk.resetVocabularyToDefault",
        "title": "Voice: Reset Project Vocabulary to Default"
      }
    ],
    "keybindings": [
      {
        "command": "puthtotalk.toggleRecording",
        "key": "ctrl+shift+m"
      },
      {
        "command": "puthtotalk.cancelRecording",
        "key": "ctrl+alt+m",
        "when": "puthtotalk.isRecording"
      },
      {
        "command": "puthtotalk.showLog",
        "key": "ctrl+shift+l"
      }
    ],
    "views": {
      "puthtotalk-sidebar": [
        {
          "type": "webview",
          "id": "puthtotalk.voiceLog",
          "name": "Voice Log"
        },
        {
          "type": "webview",
          "id": "puthtotalk.voiceTranscripts",
          "name": "Voice Transcripts"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "puthtotalk-sidebar",
          "title": "PuthToTalk",
          "icon": "media/icons/microphone.svg"
        }
      ]
    },
    "configuration": {
      "title": "PuthToTalk",
      "properties": {
        "puthtotalk.model": {
          "type": "string",
          "default": "large-v3",
          "enum": [
            "tiny",
            "base",
            "small",
            "medium",
            "large-v2",
            "large-v3"
          ],
          "description": "Whisper model to use for transcription"
        },
        "puthtotalk.device": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "cuda:0",
            "cuda:1",
            "cpu"
          ],
          "description": "Compute device for Whisper"
        },
        "puthtotalk.language": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "ru",
            "uk",
            "en",
            "de",
            "fr",
            "es",
            "it",
            "pl"
          ],
          "description": "Transcription language (auto = detect)"
        },
        "puthtotalk.mode": {
          "type": "string",
          "default": "push-to-talk",
          "enum": [
            "push-to-talk",
            "toggle"
          ],
          "description": "Recording mode"
        },
        "puthtotalk.computeType": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "float16",
            "int8_float16",
            "int8",
            "float32"
          ],
          "description": "Compute type for faster-whisper"
        },
        "puthtotalk.vadFilter": {
          "type": "boolean",
          "default": true,
          "description": "Enable voice activity detection filter"
        },
        "puthtotalk.stopDelayMs": {
          "type": "number",
          "default": 1000,
          "minimum": 0,
          "maximum": 5000,
          "description": "Extra recording time (ms) after Stop is pressed, so the last words are not cut off"
        },
        "puthtotalk.streamingMode": {
          "type": "string",
          "default": "off",
          "enum": [
            "off",
            "on",
            "adaptive"
          ],
          "enumDescriptions": [
            "Classic: record, stop, then transcribe in one shot. Best accuracy on short messages.",
            "Live: transcribe continuously while you speak. Requires a CUDA GPU; on CPU it will overload the machine.",
            "Adaptive: stay in classic mode for short messages, switch to live mode automatically once recording exceeds the threshold. Requires a CUDA GPU for the live phase."
          ],
          "description": "Streaming transcription mode. 'adaptive' runs short recordings in classic mode (more accurate) and only engages live transcription on long ones (faster final result on long context)."
        },
        "puthtotalk.adaptiveStreamingThresholdSec": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 300,
          "description": "In adaptive streaming mode, recording switches to live transcription once it exceeds this many seconds."
        },
        "puthtotalk.streamingIntervalSec": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 10,
          "description": "How often (seconds) the streaming transcriber emits a partial result"
        },
        "puthtotalk.beamSize": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 10,
          "description": "Beam size for Whisper decoding"
        },
        "puthtotalk.serverPort": {
          "type": "number",
          "default": 0,
          "description": "Python server port (0 = auto)"
        },
        "puthtotalk.log.maxRecords": {
          "type": "number",
          "default": 1000,
          "description": "Maximum records per project log"
        },
        "puthtotalk.log.onLimitExceeded": {
          "type": "string",
          "default": "delete-oldest",
          "enum": [
            "delete-oldest",
            "delete-non-starred",
            "archive",
            "ask"
          ],
          "description": "What to do when log limit is exceeded"
        },
        "puthtotalk.log.autoOpenPanel": {
          "type": "boolean",
          "default": false,
          "description": "Auto-open Voice Log panel on VS Code start"
        },
        "puthtotalk.log.groupBy": {
          "type": "string",
          "default": "day",
          "enum": [
            "day",
            "week",
            "none"
          ],
          "description": "Group records by time period"
        },
        "puthtotalk.log.showNotificationOnTranscribe": {
          "type": "boolean",
          "default": true,
          "description": "Show toast notification after transcription"
        },
        "puthtotalk.log.multiRootFolder": {
          "type": "number",
          "default": 0,
          "description": "Folder index for multi-root workspace log storage"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "ws": "^8.18.0"
  }
}
